<?xml version="1.0" encoding="utf-8"?>
<!--
  Firebase Remote Config defaults — synced with firebase/remote-config.json.
  These are used on first install before the first server fetch completes.
-->
<defaults>
    <entry>
        <key>enable_pip_chat</key>
        <value>true</value>
    </entry>
    <entry>
        <key>enable_reactive_mascot</key>
        <value>true</value>
    </entry>
    <entry>
        <key>model_download_retry_count</key>
        <value>3</value>
    </entry>
</defaults>
